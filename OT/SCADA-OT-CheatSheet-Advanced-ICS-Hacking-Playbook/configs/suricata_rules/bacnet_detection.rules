alert udp $EXTERNAL_NET any -> $HOME_NET $BACNET_PORT ( \
    msg:"BACNET_WARM_RESTART"; \
    flow:to_server; \
    content:"|81|"; depth:1; \
    content:"|00|"; distance:3; within:1; \
    content:"|14|"; distance:0; within:1; \
    content:"|01|"; distance:0; within:5; \
    threshold:type threshold, track by_src, count 1, seconds 3600; \
    classtype:attempted-admin; \
    metadata: attack_technique=T0858, attack_tactic=Inhibit_Response_Function; \
    metadata: tag=SCADA-OT-CHEATSHEET, tag=redteam, tag=bacnet; \
    priority:2; \
    sid:430007; rev:1; gid:1; \
    reference:url,github.com/ridpath/SCADA-OT-CheatSheet-Advanced-ICS-Hacking-Playbook; \
)

# BACnet COV Subscription Excessive
# Detects abnormal Change-of-Value subscription patterns
# Aligned with tools/bacnet_security_assessment/bacnet_assessment.py:subscribe_cov()
# MITRE: T0801 - Monitor Process State, T0802 - Automated Collection
# Priority: Medium - data collection
alert udp $EXTERNAL_NET any -> $HOME_NET $BACNET_PORT ( \
    msg:"BACNET_COV_SUBSCRIPTION_STORM"; \
    flow:to_server; \
    content:"|81|"; depth:1; \
    content:"|00|"; distance:3; within:1; \
    content:"|05|"; distance:0; within:1; \
    detection_filter:track by_src, count 10, seconds 60; \
    classtype:suspicious-traffic; \
    metadata: attack_technique=T0802, attack_tactic=Collection; \
    metadata: tag=SCADA-OT-CHEATSHEET, tag=redteam, tag=bacnet; \
    priority:3; \
    sid:430008; rev:1; gid:1; \
    reference:url,github.com/ridpath/SCADA-OT-CheatSheet-Advanced-ICS-Hacking-Playbook; \
)

# BACnet AtomicWriteFile - Project Infection
# Detects file write operations (potential project file infection)
# Aligned with tools/bacnet_security_assessment/bacnet_assessment.py:atomic_write_file()
# MITRE: T0873 - Project File Infection, T0871 - Execution through API
# Priority: Critical - project file manipulation
alert udp $EXTERNAL_NET any -> $HOME_NET $BACNET_PORT ( \
    msg:"BACNET_ATOMIC_WRITE_FILE"; \
    flow:to_server; \
    content:"|81|"; depth:1; \
    content:"|00|"; distance:3; within:1; \
    content:"|07|"; distance:0; within:1; \
    dsize:>200; \
    threshold:type threshold, track by_src, count 1, seconds 300; \
    classtype:attempted-admin; \
    metadata: attack_technique=T0873, attack_tactic=Persistence; \
    metadata: tag=SCADA-OT-CHEATSHEET, tag=redteam, tag=bacnet; \
    priority:1; \
    sid:430009; rev:1; gid:1; \
    reference:url,github.com/ridpath/SCADA-OT-CheatSheet-Advanced-ICS-Hacking-Playbook; \
)

# BACnet AtomicReadFile - Data Exfiltration
# Detects file read operations (potential data exfiltration)
# MITRE: T0802 - Automated Collection
# Priority: High - data exfiltration
alert udp $EXTERNAL_NET any -> $HOME_NET $BACNET_PORT ( \
    msg:"BACNET_ATOMIC_READ_FILE"; \
    flow:to_server; \
    content:"|81|"; depth:1; \
    content:"|00|"; distance:3; within:1; \
    content:"|06|"; distance:0; within:1; \
    threshold:type threshold, track by_src, count 5, seconds 300; \
    classtype:suspicious-traffic; \
    metadata: attack_technique=T0802, attack_tactic=Collection; \
    metadata: tag=SCADA-OT-CHEATSHEET, tag=redteam, tag=bacnet; \
    priority:2; \
    sid:430010; rev:1; gid:1; \
    reference:url,github.com/ridpath/SCADA-OT-CheatSheet-Advanced-ICS-Hacking-Playbook; \
)

# BACnet Service Fuzzing Detection
# Detects malformed BACnet packets (fuzzing attempts)
# Aligned with tools/bacnet_security_assessment/bacnet_assessment.py:fuzz_service()
# MITRE: T0855 - Unauthorized Command Message
# Priority: High - vulnerability discovery
alert udp $EXTERNAL_NET any -> $HOME_NET $BACNET_PORT ( \
    msg:"BACNET_SERVICE_FUZZING"; \
    flow:to_server; \
    content:"|81|"; depth:1; \
    dsize:>1000; \
    detection_filter:track by_src, count 5, seconds 60; \
    classtype:attempted-admin; \
    metadata: attack_technique=T0855, attack_tactic=Impair_Process_Control; \
    metadata: tag=SCADA-OT-CHEATSHEET, tag=redteam, tag=bacnet; \
    priority:2; \
    sid:430011; rev:1; gid:1; \
    reference:url,github.com/ridpath/SCADA-OT-CheatSheet-Advanced-ICS-Hacking-Playbook; \
)

# BACnet MS/TP Token Manipulation
# Detects MS/TP token passing attacks (via serial/Ethernet gateway)
# Aligned with tools/bacnet_security_assessment/bacnet_assessment.py:mstp_token_manipulation()
# MITRE: T0803 - Block Command Message, T0804 - Block Reporting Message
# Priority: High - network disruption
alert tcp $EXTERNAL_NET any -> $HOME_NET any ( \
    msg:"BACNET_MSTP_TOKEN_MANIPULATION"; \
    flow:established,to_server; \
    content:"MS/TP"; \
    content:"|00|"; distance:0; within:10; \
    pcre:"/\x55\xFF.[\x00-\x07]/s"; \
    threshold:type threshold, track by_src, count 10, seconds 60; \
    classtype:protocol-command-decode; \
    metadata: attack_technique=T0803, attack_tactic=Inhibit_Response_Function; \
    metadata: tag=SCADA-OT-CHEATSHEET, tag=redteam, tag=bacnet; \
    priority:2; \
    sid:430012; rev:1; gid:1; \
    reference:url,github.com/ridpath/SCADA-OT-CheatSheet-Advanced-ICS-Hacking-Playbook; \
)

# BACnet WritePropertyMultiple - Bulk Modification
# Detects bulk property modification
# MITRE: T0836 - Modify Parameter
# Priority: High - bulk control manipulation
alert udp $EXTERNAL_NET any -> $HOME_NET $BACNET_PORT ( \
    msg:"BACNET_WRITE_PROPERTY_MULTIPLE"; \
    flow:to_server; \
    content:"|81|"; depth:1; \
    content:"|00|"; distance:3; within:1; \
    content:"|10|"; distance:0; within:1; \
    dsize:>300; \
    threshold:type threshold, track by_src, count 2, seconds 300; \
    classtype:protocol-command-decode; \
    metadata: attack_technique=T0836, attack_tactic=Impair_Process_Control; \
    metadata: tag=SCADA-OT-CHEATSHEET, tag=redteam, tag=bacnet; \
    priority:2; \
    sid:430013; rev:1; gid:1; \
    reference:url,github.com/ridpath/SCADA-OT-CheatSheet-Advanced-ICS-Hacking-Playbook; \
)

