# BACnet Security Detection Rules for Suricata
# Author: ICS Security Research Team
# GitHub: https://github.com/ridpath/SCADA-OT-CheatSheet-Advanced-ICS-Hacking-Playbook
# Purpose: Detect BACnet/IP and MS/TP security attacks
# Version: 1.0
# Aligned with: tools/bacnet_security_assessment/bacnet_assessment.py
#
# Variables (define in suricata.yaml for production use)
# HOME_NET: [192.168.0.0/16]
# EXTERNAL_NET: !$HOME_NET
# AUTHORIZED_BACNET_CLIENTS: [192.168.1.50, 192.168.1.51]
# BACNET_PORT: 47808

# BACnet Who-Is Broadcast Storm
# Detects excessive device discovery attempts
# Aligned with tools/bacnet_security_assessment/bacnet_assessment.py:discover_devices()
# MITRE: T0888 - Remote System Information Discovery, T0868 - Detect Operating Mode
# Priority: Medium - reconnaissance activity
alert udp $EXTERNAL_NET any -> $HOME_NET $BACNET_PORT ( \
    msg:"BACNET_WHOIS_BROADCAST_STORM"; \
    flow:to_server; \
    content:"|81|"; depth:1; \
    content:"|0a|"; distance:3; within:1; \
    content:"|08|"; distance:0; within:1; \
    detection_filter:track by_src, count 10, seconds 60; \
    classtype:network-scan; \
    metadata: attack_technique=T0888, attack_tactic=Discovery; \
    metadata: tag=SCADA-OT-CHEATSHEET, tag=redteam, tag=bacnet; \
    priority:3; \
    sid:430001; rev:1; gid:1; \
    reference:url,github.com/ridpath/SCADA-OT-CheatSheet-Advanced-ICS-Hacking-Playbook; \
)

# BACnet WriteProperty from Unauthorized Source
# Detects unauthorized write operations
# Aligned with tools/bacnet_security_assessment/bacnet_assessment.py:write_property()
# MITRE: T0855 - Unauthorized Command Message, T0836 - Modify Parameter
# Priority: High - unauthorized control
alert udp !$AUTHORIZED_BACNET_CLIENTS any -> $HOME_NET $BACNET_PORT ( \
    msg:"BACNET_UNAUTHORIZED_WRITE_PROPERTY"; \
    flow:to_server; \
    content:"|81|"; depth:1; \
    content:"|00|"; distance:3; within:1; \
    content:"|0f|"; distance:0; within:1; \
    classtype:protocol-command-decode; \
    metadata: attack_technique=T0855, attack_tactic=Impair_Process_Control; \
    metadata: tag=SCADA-OT-CHEATSHEET, tag=redteam, tag=bacnet; \
    priority:2; \
    sid:430002; rev:1; gid:1; \
    reference:url,github.com/ridpath/SCADA-OT-CheatSheet-Advanced-ICS-Hacking-Playbook; \
)

# BACnet ReadProperty Multiple Enumeration
# Detects excessive property enumeration
# Aligned with tools/bacnet_security_assessment/bacnet_assessment.py:enumerate_objects()
# MITRE: T0861 - Point & Tag Identification
# Priority: Medium - reconnaissance activity
alert udp $EXTERNAL_NET any -> $HOME_NET $BACNET_PORT ( \
    msg:"BACNET_PROPERTY_ENUMERATION"; \
    flow:to_server; \
    content:"|81|"; depth:1; \
    content:"|00|"; distance:3; within:1; \
    content:"|0c|"; distance:0; within:1; \
    detection_filter:track by_src, count 20, seconds 60; \
    classtype:network-scan; \
    metadata: attack_technique=T0861, attack_tactic=Collection; \
    metadata: tag=SCADA-OT-CHEATSHEET, tag=redteam, tag=bacnet; \
    priority:3; \
    sid:430003; rev:1; gid:1; \
    reference:url,github.com/ridpath/SCADA-OT-CheatSheet-Advanced-ICS-Hacking-Playbook; \
)

# BACnet Priority Array Manipulation
# Detects priority override attacks
# Aligned with tools/bacnet_security_assessment/bacnet_assessment.py:manipulate_priority_array()
# MITRE: T0855 - Unauthorized Command Message, T0836 - Modify Parameter
# Priority: Critical - control override
alert udp $EXTERNAL_NET any -> $HOME_NET $BACNET_PORT ( \
    msg:"BACNET_PRIORITY_ARRAY_OVERRIDE"; \
    flow:to_server; \
    content:"|81|"; depth:1; \
    content:"|00|"; distance:3; within:1; \
    content:"|0f|"; distance:0; within:1; \
    content:"|57|"; distance:0; within:10; \
    threshold:type threshold, track by_src, count 1, seconds 300; \
    classtype:attempted-admin; \
    metadata: attack_technique=T0836, attack_tactic=Impair_Process_Control; \
    metadata: tag=SCADA-OT-CHEATSHEET, tag=redteam, tag=bacnet; \
    priority:1; \
    sid:430004; rev:1; gid:1; \
    reference:url,github.com/ridpath/SCADA-OT-CheatSheet-Advanced-ICS-Hacking-Playbook; \
)

# BACnet DeviceCommunicationControl
# Detects attempts to disable device communication
# Aligned with tools/bacnet_security_assessment/bacnet_assessment.py:device_communication_control()
# MITRE: T0803 - Block Command Message, T0804 - Block Reporting Message
# Priority: Critical - communication disruption
alert udp $EXTERNAL_NET any -> $HOME_NET $BACNET_PORT ( \
    msg:"BACNET_DEVICE_COMMUNICATION_CONTROL"; \
    flow:to_server; \
    content:"|81|"; depth:1; \
    content:"|00|"; distance:3; within:1; \
    content:"|11|"; distance:0; within:1; \
    threshold:type threshold, track by_src, count 1, seconds 3600; \
    classtype:attempted-admin; \
    metadata: attack_technique=T0803, attack_tactic=Inhibit_Response_Function; \
    metadata: tag=SCADA-OT-CHEATSHEET, tag=redteam, tag=bacnet; \
    priority:1; \
    sid:430005; rev:1; gid:1; \
    reference:url,github.com/ridpath/SCADA-OT-CheatSheet-Advanced-ICS-Hacking-Playbook; \
)

# BACnet ReinitializeDevice - Cold Restart
# Detects device cold restart commands
# Aligned with tools/bacnet_security_assessment/bacnet_assessment.py:reinitialize_device()
# MITRE: T0858 - Change Operating Mode, T0871 - Execution through API
# Priority: Critical - service disruption
alert udp $EXTERNAL_NET any -> $HOME_NET $BACNET_PORT ( \
    msg:"BACNET_COLD_RESTART"; \
    flow:to_server; \
    content:"|81|"; depth:1; \
    content:"|00|"; distance:3; within:1; \
    content:"|14|"; distance:0; within:1; \
    content:"|00|"; distance:0; within:5; \
    threshold:type threshold, track by_src, count 1, seconds 3600; \
    classtype:attempted-admin; \
    metadata: attack_technique=T0858, attack_tactic=Inhibit_Response_Function; \
    metadata: tag=SCADA-OT-CHEATSHEET, tag=redteam, tag=bacnet; \
    priority:1; \
    sid:430006; rev:1; gid:1; \
    reference:url,github.com/ridpath/SCADA-OT-CheatSheet-Advanced-ICS-Hacking-Playbook; \
)

# BACnet ReinitializeDevice - Warm Restart
# Detects device warm restart commands
# MITRE: T0858 - Change Operating Mode, T0871 - Execution through API
